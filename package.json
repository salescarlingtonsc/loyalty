{
  "name": "frenly-static-production-baseline",
  "version": "0.0.0",
  "private": true,
  "description": "Production-safety checks for the Frenly static app.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "quality": "node scripts/quality/static-baseline.mjs",
    "runtime-config:check": "node scripts/runtime-config/generate.mjs --config config/runtime/production.json --check",
    "migration-manifest:check": "node scripts/migrations/generate-manifest.mjs --check",
    "canonical-migrations:plan:check": "node scripts/migrations/materialize-canonical-order.mjs --check-plan",
    "canonical-migrations:materialize": "node scripts/migrations/materialize-canonical-order.mjs --materialize",
    "canonical-migrations:check": "node scripts/migrations/materialize-canonical-order.mjs --check",
    "test": "node --test",
    "build": "node scripts/quality/build-static.mjs",
    "validate": "npm run quality && npm run runtime-config:check && npm run migration-manifest:check && npm run canonical-migrations:plan:check && npm test && npm run build"
  }
}
